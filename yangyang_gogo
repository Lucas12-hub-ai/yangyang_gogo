<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> 청년센터 양양 단합 비밀미션</title>
    <style>
        /* 기본 설정 */
        :root {
            --gold: #c5a059;
            --deep-blue: #0f0c29;
            --mystic-purple: #302b63;
            --cream: #f3f0df;
        }

        body {
            background: linear-gradient(to bottom, #0f0c29, #302b63, #24243e);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Pretendard', sans-serif;
            color: var(--cream);
            overflow-x: hidden;
        }

        h1 {
            font-size: 1.8rem;
            color: var(--gold);
            text-shadow: 0 0 10px rgba(197, 160, 89, 0.5);
            margin-bottom: 5px;
        }

        .subtitle {
            font-size: 0.9rem;
            opacity: 0.8;
            margin-bottom: 30px;
        }

        /* 카드 컨테이너 (3D 환경) */
        .card-container {
            perspective: 1000px;
            width: 300px;
            height: 480px;
            cursor: pointer;
            position: relative;
        }

        /* 실제 카드 */
        .card {
            width: 100%;
            height: 100%;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
            border-radius: 20px;
        }

        /* 카드가 뒤집혔을 때의 상태 */
        .card.is-flipped {
            transform: rotateY(180deg);
        }

        /* 카드 앞/뒷면 공통 */
        .card-face {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border-radius: 20px;
            border: 5px solid var(--gold);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            box-sizing: border-box;
        }

        /* 카드 앞면 (닫힌 상태 - 타로 문양) */
        .card-front {
            background: #1a1a2e;
            background-image: 
                radial-gradient(circle at 50% 50%, rgba(197, 160, 89, 0.1) 0%, transparent 80%),
                url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0l3 27 27 3-27 3-3 27-3-27-27-3 27-3z' fill='%23c5a059' fill-opacity='0.1'/%3E%3C/svg%3E");
        }

        .card-front::after {
            content: "SECRET\nMISSION";
            white-space: pre;
            text-align: center;
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--gold);
            letter-spacing: 5px;
            border: 1px solid var(--gold);
            padding: 20px;
        }

        /* 카드 뒷면 (미션 공개 상태) */
        .card-back {
            background: var(--cream);
            color: #1a1a2e;
            transform: rotateY(180deg);
        }

        .mission-cat {
            font-size: 0.8rem;
            color: #8b733a;
            font-weight: bold;
            margin-bottom: 15px;
            text-transform: uppercase;
            border-bottom: 1px solid #8b733a;
            padding-bottom: 5px;
        }

        .mission-text {
            font-size: 1.3rem;
            font-weight: 800;
            line-height: 1.6;
            word-break: keep-all;
        }

        /* 조작 버튼 */
        .controls {
            margin-top: 40px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            width: 300px;
        }

        button {
            padding: 15px 30px;
            font-size: 1rem;
            font-weight: bold;
            border: 2px solid var(--gold);
            background: transparent;
            color: var(--gold);
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s;
        }

        button:hover {
            background: var(--gold);
            color: white;
            box-shadow: 0 0 20px rgba(197, 160, 89, 0.4);
        }

        button:active {
            transform: scale(0.95);
        }
    </style>
</head>
<body>

    <h1>🕵️‍♂️ 신학부 비밀 미션</h1>
    <p class="subtitle">미스틱 타로 에디션</p>

    <div class="card-container" onclick="flipCard()">
        <div class="card" id="card">
            <div class="card-face card-front"></div>
            <div class="card-face card-back">
                <div id="m-cat" class="mission-cat">운명을 뽑아주세요</div>
                <div id="m-text" class="mission-text">중앙 버튼을 눌러<br>운명을 확인하세요.</div>
            </div>
        </div>
    </div>

    <div class="controls">
        <button onclick="drawNewMission()">새로운 운명 뽑기 🎲</button>
    </div>

    <script>
        const missions = [
            { cat: "유형 1: 하늘에 촥! 붙기!", text: "담당 강사님(주강사님, 총무님)과 함께 손가락 하트 만들고 셀카 찍기" },
            { cat: "유형 1: 하늘에 촥! 붙기!", text: "총무님께 '오늘따라 참 귀여우시네요' 혹은 '귀엽다'는 말 듣기" },
            { cat: "유형 1: 하늘에 촥! 붙기!", text: "담당 강사님(주강사님)과 기분 좋게 '하이파이브' 2번 하기" },
            { cat: "유형 1: 하늘에 촥! 붙기!", text: "총무님과 나란히 서서 팔짱끼고 사진 찍기" },
            { cat: "유형 2: 사명자 친밀도 UP", text: "다른 차량 사명자에게 전화를 걸어 '사랑합니다, 연합합시다!' 외치고 끊기" },
            { cat: "유형 2: 사명자 친밀도 UP", text: "오늘 파란색(또는 특정색) 아이템을 착용한 사명자 찾아 패션 칭찬하기" },
            { cat: "유형 2: 사명자 친밀도 UP", text: "카페나 식당에서 다른 사명자의 빈 컵이나 쓰레기 3개 이상 대신 치워주기" },
            { cat: "유형 2: 사명자 친밀도 UP", text: "누군가의 고민을 듣게 된다면 '제가 오늘 꼭 기도할게요'라고 답해주기" },
            { cat: "유형 2: 사명자 친밀도 UP", text: "5명 이상 모인 곳에서 '우리는 하나!' 선창하고 후창 유도하기" },
            { cat: "유형 2: 사명자 친밀도 UP", text: "오늘 하루 동안 서로 다른 사명자 5명에게 '엄지 척' 날려주기" },
            { cat: "유형 2: 사명자 친밀도 UP", text: "상대방에게 'OO님은 진짜 센터의 기둥이세요'라고 말해주기" },
            { cat: "유형 3: 텐션 UP! 웃음 유발", text: "바다를 향해 '양양아! 내가 왔다!' 라고 크게 외치기 (최소 3명 동반)" },
            { cat: "유형 3: 텐션 UP! 웃음 유발", text: "사진 찍어주는 척하면서 내 얼굴 셀카 3장 몰래 찍어두기" },
            { cat: "유형 3: 텐션 UP! 웃음 유발", text: "5명 이상 모인 곳에서 갑자기 스쿼트 10개 하기" },
            { cat: "유형 3: 텐션 UP! 웃음 유발", text: "하늘을 가리키며 '와! 저 구름 모양 진짜 신기하다!'라고 말해 3명 이상 쳐다보게 만들기" },
            { cat: "유형 3: 텐션 UP! 웃음 유발", text: "이동 중 차 안에서 무반주로 노래 한 구절 부르고 박수 유도하기" },
            { cat: "유형 3: 텐션 UP! 웃음 유발", text: "사람들 앞에서 당당하게 '모델 워킹'으로 5미터 걷기" },
            { cat: "유형 3: 텐션 UP! 웃음 유발", text: "카페 대화 중 갑자기 일어서서 1분간 미니 스피치하기 (주제 자유)" },
            { cat: "유형 3: 텐션 UP! 웃음 유발", text: "주변 사람 중 한 명의 특징이나 말투 10초간 흉내 내기 (기분 좋게!)" },
            { cat: "유형 3: 텐션 UP! 웃음 유발", text: "서피비치 백사장에 '사랑해요♡ 청년센터!' 크게 쓰고 인증샷 찍기" },
            { cat: "유형 3: 텐션 UP! 웃음 유발", text: "카페 음악에 맞춰 아주 진지하고 우아하게 손가락 지휘 30초간 하기" },
            { cat: "유형 4: 일상 소소 미션", text: "상대방과 가위바위보를 해서 연속 2번 이기기 (내기 금지!)" },
            { cat: "유형 4: 일상 소소 미션", text: "누군가 영상 촬영을 할 때 뒤에서 몰래 '꽃받침' 포즈로 출연하기" },
            { cat: "유형 4: 일상 소소 미션", text: "물병이나 소지품을 머리 위에 올리고 5초간 버티기 성공하기" },
            { cat: "유형 4: 일상 소소 미션", text: "상대방에게 '와, 오늘 진짜 에너지 넘치시네요!'라는 말 듣기" },
            { cat: "유형 4: 일상 소소 미션", text: "일명 '아재 개그' 하나 던져서 누군가를 피식 웃게 만들기" },
            { cat: "유형 4: 일상 소소 미션", text: "서피비치 주변의 쓰레기 3개 주워서 쓰레기통에 버리기" }
        ];

        const card = document.getElementById('card');
        const mCat = document.getElementById('m-cat');
        const mText = document.getElementById('m-text');

        // 카드 수동 뒤집기
        function flipCard() {
            card.classList.toggle('is-flipped');
        }

        // 새 미션 뽑기
        function drawNewMission() {
            // 이미 뒤집혀 있다면 먼저 닫기
            if (card.classList.contains('is-flipped')) {
                card.classList.remove('is-flipped');
                
                // 카드가 완전히 닫힌 후(0.4초 뒤) 텍스트 변경
                setTimeout(() => {
                    setRandomMission();
                    card.classList.add('is-flipped');
                }, 400);
            } else {
                setRandomMission();
                card.classList.add('is-flipped');
            }
        }

        function setRandomMission() {
            const randomIndex = Math.floor(Math.random() * missions.length);
            mCat.innerText = missions[randomIndex].cat;
            mText.innerText = missions[randomIndex].text;
        }
    </script>
</body>
</html>
